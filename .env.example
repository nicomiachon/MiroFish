# ===== LLM Provider =====
# "openai" (default) or "bedrock"
LLM_PROVIDER=openai

# ===== OpenAI-compatible LLM config (when LLM_PROVIDER=openai) =====
# Supports any OpenAI SDK compatible API
# Recommended: Alibaba Qwen Plus via https://bailian.console.aliyun.com/
# Note: high token consumption, start with <40 round simulations
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== AWS Bedrock config (when LLM_PROVIDER=bedrock) =====
# AWS_REGION=eu-west-1
# BEDROCK_API_KEY=ABSK...
# CLAUDE_MODEL=eu.anthropic.claude-sonnet-4-6

# ===== Zep Cloud =====
# Free monthly quota available: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Boost LLM config (optional) =====
# Leave these out entirely if not using boost config
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here
